// GET /api/v1/proposals/:id
app.get('/api/v1/proposals/:id', (c) => {
  const id = c.req.param('id')
  const proposal = proposals.find(p => p.id === id)
  if (!proposal) {
    return c.json({ error: { message: 'Proposal not found', code: 'NOT_FOUND' } }, 404)
  }
  return c.json({ data: proposal })
})

// POST /api/v1/proposals/:id/vote
const voteSchema = z.object({
  option: z.enum(['Yes', 'No', 'Abstain']),
  userId: z.string(),
})

app.post('/api/v1/proposals/:id/vote', zValidator('json', voteSchema), (c) => {
  const id = c.req.param('id')
  const { option, userId } = c.req.valid('json')
  const proposal = proposals.find(p => p.id === id)

  if (!proposal) {
    return c.json({ error: { message: 'Proposal not found', code: 'NOT_FOUND' } }, 404)
  }

  if (proposal.status !== 'VOTING') {
    return c.json({ error: { message: 'This proposal is not accepting votes', code: 'NOT_VOTING' } }, 400)
  }

  // Update vote count
  const voteIdx = proposal.votes.findIndex(v => v.option === option)
  if (voteIdx >= 0) {
    proposal.votes[voteIdx].count += 1
  }
  proposal.quorumCurrent += 1

  return c.json({
    data: {
      success: true,
      message: `You voted ${option}! 🎉 You're voter #${proposal.quorumCurrent} of ${proposal.quorumRequired} needed.`,
      quorumCurrent: proposal.quorumCurrent,
      votes: proposal.votes,
    },
  })
})

